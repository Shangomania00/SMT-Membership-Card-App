{
    "compilerOptions":  {
                            "tsBuildInfoFile":  "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
                            "target":  "ES2022",
                            "lib":  [
                                        "ES2022"
                                    ],
                            "module":  "ESNext",
                            "types":  [
                                          "node"
                                      ],
                            "skipLibCheck":  true,
                            "moduleResolution":  "bundler",
                            "allowImportingTsExtensions":  true,
                            "moduleDetection":  "force",
                            "noEmit":  true,
                            "strict":  false,
                            "esModuleInterop":  true,
                            "noFallthroughCasesInSwitch":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ],
                                          "@contracts/*":  [
                                                               "./contracts/*"
                                                           ],
                                          "@db/*":  [
                                                        "./db/*"
                                                    ]
                                      },
                            "outDir":  "./dist"
                        },
    "include":  [
                    "api/**/*",
                    "db/**/*",
                    "contracts/**/*",
                    "types/**/*"
                ]
}

